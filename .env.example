# ECHO environment configuration
# Copy this file to `.env` for the FastAPI service. For Next.js, place the
# NEXT_PUBLIC_* values in `apps/web/.env.local` (or configure them in Vercel).
# Never expose server-only values to the browser or commit a populated .env.

# -----------------------------------------------------------------------------
# Next.js browser configuration (safe to expose)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# In Supabase Auth, add these redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR_WEB_DOMAIN/auth/callback
# Enable Email/Password plus Google and GitHub providers before using OAuth.

# -----------------------------------------------------------------------------
# FastAPI / Supabase (required; server-only)
# -----------------------------------------------------------------------------
# Use Supabase's Session or Transaction pooler URL for reliable hosted access;
# do not use a browser URL here.
DATABASE_URL=postgresql://postgres:your_password@your_pooler_host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# -----------------------------------------------------------------------------
# Gemini Live and Groq (required; server-only)
# -----------------------------------------------------------------------------
# Gemini Live uses an ephemeral token minted by the API; never expose this key.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Groq's free/developer-tier availability and model catalogue may change.
GROQ_API_KEY=your_groq_api_key
GROQ_PERSONA_MODEL=llama-3.3-70b-versatile
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# -----------------------------------------------------------------------------
# Pinecone (required; server-only)
# PINECONE_INDEX is the actual production index used by the application.
# PINECONE_INDEX_NAME is retained for compatibility with existing deployments.
# -----------------------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=echo-memories
PINECONE_INDEX_NAME=echo-memories
PINECONE_ENVIRONMENT=us-east-1

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
DEVELOPMENT_MODE=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000