# FastAPI Backend Environment Template

# App Settings
DEMO_MODE=true
DEVELOPMENT_MODE=true
CORS_ORIGINS="https://echo-web.vercel.app"

# OpenAI Integrations
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime-2.1"
OPENAI_PERSONA_MODEL="gpt-4.1-mini"

# PostgreSQL / Supabase
# If deploying on Railway, DATABASE_URL is automatically populated.
DATABASE_URL=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# Pinecone Vector Database
PINECONE_API_KEY=""
PINECONE_INDEX="echo-memories"
PINECONE_ENVIRONMENT="us-east-1"

# Redis / Celery
# If deploying on Railway, REDIS_URL is automatically populated.
REDIS_URL=""
