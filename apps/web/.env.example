# Next.js Frontend Environment Template

# Public browser configuration. Never add service-role, provider, database, or
# Pinecone keys here; they must remain in the FastAPI deployment only.
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
